# ── Flutter ─────────────────────────────────────────────────────────────────
mobile/.dart_tool/
mobile/.flutter-plugins
mobile/.flutter-plugins-dependencies
mobile/build/
mobile/.packages
mobile/pubspec.lock  # Include this for reproducible builds on teams — remove this line

# Firebase emulator logs
firebase/firebase-debug.log
firebase/firestore-debug.log
firebase/ui-debug.log
firebase/database-debug.log

# firebase_options.dart is intentionally tracked (client config is safe to commit)

# Android local config
mobile/android/local.properties
mobile/android/key.properties
mobile/android/*.jks

# ── Python / FastAPI ─────────────────────────────────────────────────────────
backend/__pycache__/
backend/**/__pycache__/
backend/*.pyc
backend/*.pyo
backend/venv/
backend/.venv/
backend/.env                       # Never commit real env values
backend/firebase-service-account.json  # Never commit service account key
backend/models/*.pkl               # Trained model files (too large for git)
backend/models/*.h5

# ── IDE ──────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── CI artifacts ─────────────────────────────────────────────────────────────
coverage/
.coverage
htmlcov/
